# Perplexity API key — required. Get one at https://www.perplexity.ai/settings/api
PPLX_API_KEY=

# Default model. sonar | sonar-pro | sonar-reasoning | sonar-reasoning-pro | sonar-deep-research
PPLX_MODEL=sonar-pro

# Output directory (where each query is saved as a .md file)
PPLX_RAW_DIR=

# Wiki directory (for sources/ summary pages and log.md)
PPLX_WIKI_DIR=

# Monthly budget in USD. CLI refuses to run when this month's spend would exceed it.
PPLX_MONTHLY_BUDGET_USD=5

# Pricing for sonar-pro (USD per 1M tokens / per 1K requests). Override per Perplexity's current rate card.
PPLX_PRICE_INPUT_PER_M=3
PPLX_PRICE_OUTPUT_PER_M=15
PPLX_PRICE_REQUEST_PER_K=5

# Usage ledger location (JSON, monthly aggregated)
PPLX_USAGE_FILE=

# Firecrawl API key. Get one from your Firecrawl account.
# Used when Perplexity fails, needs citation backup, or you want direct web search/scrape.
FIRECRAWL_API_KEY=
FIRECRAWL_API_BASE=https://api.firecrawl.dev/v2

# Tavily API key. Get one from https://app.tavily.com
# Used as tertiary search fallback when Perplexity and Firecrawl are unavailable or insufficient.
TAVILY_API_KEY=
TAVILY_API_BASE=https://api.tavily.com
TAVILY_PROJECT=

# === web-research skill (~/.claude/skills/web-research) ===
# Comma-separated relay order. Reorder to change which tool is tried first.
# Supported tokens: perplexity, tavily, firecrawl, browser
WEB_RESEARCH_TOOL_PRIORITY=perplexity,tavily,firecrawl,browser

# Minimum distinct sources required before moving on to report synthesis.
# If fewer sources are found after trying every tool in priority order, the
# skill proceeds anyway but flags the report as low-confidence.
WEB_RESEARCH_MIN_SOURCES=3

# Where raw per-tool search results are collected before synthesis.
WEB_RESEARCH_RAW_DIR=

# Where the synthesized Markdown report is saved.
WEB_RESEARCH_REPORT_DIR=
